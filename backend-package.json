    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.2",
    "bcrypt": "^5.1.1",
    "axios": "^1.6.2",
    "zod": "^4.1.13",
    "pino": "^8.17.2",
    "pino-http": "^8.5.0",
    "pino-pretty": "^10.2.3",
    "bull": "^4.11.4",
